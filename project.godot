config_version=5

[application]

config/name="BrainCellGameProtyping02"
run/main_scene="uid://dxe7ce5123xhv"
config/features=PackedStringArray("4.6", "Forward Plus")

[audio]

buses/default_bus_layout=""

[autoload]

