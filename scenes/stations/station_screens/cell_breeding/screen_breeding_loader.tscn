		if (in_red > 0.5) {

			if (in_yellow > 0.5) {
				result = mix(
					result,
					vec4(red_color.rgb, tex.a),
					overlap_opacity
				);
			}
			else {
				result = vec4(red_color.rgb, tex.a);
			}
		}

		// Change stripe
		float left = min(start_value, prisoner_value);
		float right = max(start_value, prisoner_value);

		if (
			right - left > 0.001 &&
			UV.x >= left &&
			UV.x <= right
